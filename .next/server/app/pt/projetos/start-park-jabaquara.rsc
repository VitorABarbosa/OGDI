10:["$","$L3b",null,{"formats":"$undefined","locale":"pt","messages":{"nav":{"home":"HOME","institucional":"A OGDI","projetos":"PROJETOS","investidores":"INVESTIDORES","insights":"INSIGHTS","contato":"Contato"},"common":{"ctaHeader":"Fale com a Open Group","ctaMobile":"Apresentar oportunidade","langLabel":"Idioma: Português (Brasil). Ver outros idiomas","placeholder":{"body":"Conteúdo em preparação. Esta página faz parte da arquitetura do site e receberá conteúdo em breve.","back":"Voltar para a home"},"rail":{"goTo":"Ir para {label}","defaultAria":"Navegação visual da página"}},"footer":{"tagline":"O valor nasce antes da obra.","atuacaoTitle":"Atuação","navTitle":"Navegação","privacy":"Política de Privacidade"},"home":{"rail":{"ariaLabel":"Navegação visual da página inicial","top":"Início","projetos":"Projetos","atuacao":"Atuação","modelos":"Modelos","institucional":"Manifesto","parceiros":"Parceiros","contato":"Contato"},"hero":{"srTitle":"Open Group — Desenvolvimento imobiliário. O valor nasce antes da obra.","phrase":"O valor nasce antes da obra.","prev":"Anterior","next":"Próximo","slides":{"hits-santa-catarina":{"kick":"Entregue · Empreendimento","meta":{"status":"Entregue","segmento":"Residencial","local":"São Paulo · SP"},"sign":"OGDI sócia da operação — da concepção ao lançamento."},"hits-cupece":{"kick":"Em obra · Empreendimento","meta":{"status":"Em obra","segmento":"Residencial","local":"São Paulo · SP"},"sign":"OGDI sócia da operação — leitura da oportunidade, produto e estruturação."},"start-park-jabaquara":{"kick":"Em obra · Empreendimento","meta":{"status":"Em obra","segmento":"Residencial","local":"São Paulo · SP"},"sign":"OGDI sócia da operação — inteligência de mercado, viabilidade e condução até o lançamento."},"oh-freguesia":{"kick":"Em obra · Empreendimento","meta":{"status":"Em obra","segmento":"Residencial","local":"São Paulo · SP"},"sign":"OGDI sócia da operação — conceituação do produto e estruturação."}}},"projetos":{"kicker":"Projetos","heading":"Empreendimentos que avançam.","prev":"Anterior","next":"Próximo","goTo":"Ir para {n}","seeAll":"Ver todos os projetos","tabs":{"obra":"Em obra","futuro":"Futuro lançamento","entregue":"Entregue"},"cards":{"hits-cupece":{"status":"Em obra","ctaLabel":"Conheça o empreendimento"},"start-park-jabaquara":{"status":"Em obra","ctaLabel":"Conheça o empreendimento"},"oh-freguesia":{"status":"Em obra","ctaLabel":"Conheça o empreendimento"},"guarulhos":{"status":"Futuro lançamento","ctaLabel":"Falar sobre o projeto"},"jabaquara":{"status":"Futuro lançamento","ctaLabel":"Falar sobre o projeto"},"hits-santa-catarina":{"status":"Entregue","ctaLabel":"Conheça o empreendimento"}}},"atuacao":{"kicker":"Nossa atuação","heading":"Da origem<br></br>à entrega de chaves.","intro":"A OGDI conduz a operação de ponta a ponta, da leitura da oportunidade à entrega das chaves. Produto, capital, parceiros e obra avançam sob a mesma tese.","tags":{"consultoria":"Consultoria contratada","parceria":"Parceria estratégica","societaria":"Sócia da operação","investimento":"Investimento SCP"},"steps":{"10":{"title":"Entrega de chaves","desc":"Conclusão da obra e entrega do empreendimento concluído."},"01":{"title":"Leitura da Oportunidade","desc":"Entendimento do ativo, do estágio e do potencial real de desenvolvimento."},"02":{"title":"Inteligência de mercado","desc":"Contexto de praça, demanda e leitura concorrencial que fundamenta a tese."},"03":{"title":"Estudo de viabilidade","desc":"Análise financeira e institucional que destrava o caminho da operação."},"04":{"title":"Desenvolvimento imobiliário","desc":"Definição da lógica do produto imobiliário: tipologia e posicionamento."},"05":{"title":"Estruturação financeira","desc":"Modelagem de capital, fontes de recurso e retorno alinhados ao potencial da operação."},"06":{"title":"Pré-Lançamento","desc":"Articulação de parceiros e relacionamento com banco, incluindo a CEF quando aplicável."},"07":{"title":"Lançamento","desc":"Entrada no mercado, com produto, narrativa e estratégia comercial prontos."},"08":{"title":"Início de obras","desc":"Largada da execução, com a operação estruturada e os parceiros em campo."},"09":{"title":"Habite-se","desc":"Aprovação que atesta a conclusão da obra e autoriza a ocupação do empreendimento."}}},"modelos":{"kicker":"Modelos de atuação","heading":"Atuação flexível conforme<br></br>o perfil da oportunidade.","intro":"Cada oportunidade pede um nível de envolvimento diferente. A OGDI define como entra em cada operação, da consultoria contratada à sociedade no empreendimento, conforme o estágio e o potencial do projeto.","cta":"Conheça a Open Group","cards":{"consultoria":{"idx":"i.","title":"Consultoria contratada","desc":"Apoiamos a estruturação da operação com leitura estratégica e condução técnica, dentro de um escopo definido."},"parceria":{"idx":"ii.","title":"Parceria estratégica","desc":"Atuamos lado a lado na construção do empreendimento, compartilhando visão, estrutura e direção."},"societaria":{"idx":"iii.","title":"Participação societária","desc":"Entramos como sócios da operação, comprometidos com o resultado do empreendimento de ponta a ponta."},"investimento":{"idx":"iv.","title":"Investimento SCP","desc":"Aporte direto na operação por meio de uma SCP — capital que participa do resultado, sem assumir a gestão."}}},"manifesto":{"kicker":"Sobre a Open Group","line1":"Antes da obra, existe a <em>decisão</em>.","line2":"Antes do lançamento, existe a <em>estrutura</em>.","line3":"Antes do valor, existe <em>visão</em>.","whatTitle":"O que fazemos","body1":"A Open Group Desenvolvimento Imobiliário atua na estruturação e desenvolvimento de empreendimentos imobiliários, conduzindo oportunidades da conceituação ao lançamento.","body2":"Nosso trabalho começa antes da obra: na leitura da oportunidade, na análise de viabilidade, no desenho estratégico da operação e na articulação dos parceiros necessários para o projeto avançar com consistência.","body3":"Atuamos junto a construtoras, incorporadoras, empresas com ativos imobiliários e investidores, combinando visão estratégica, estruturação financeira e institucional, conexão com parceiros e condução até as etapas críticas de mercado.","cta":"Conhecer a empresa"}},"institucional":{"rail":{"ariaLabel":"Navegação visual da página institucional","inicio":"Início","sobre":"Sobre","origem":"Origem","lideranca":"Quem conduz","grupo":"Nosso Grupo","assinatura":"Mensagem final"},"meta":{"title":"O que fazemos","description":"A Open Group estrutura e desenvolve empreendimentos imobiliários, conduzindo oportunidades da conceituação ao lançamento. O valor nasce antes da obra."},"hero":{"breadcrumbHome":"Início","breadcrumbCurrent":"O que fazemos","kicker":"O que fazemos","title1":"Revelamos o valor<br></br><em>extraordinário</em>","title2":"de oportunidades imobiliárias.","cue":"Conheça a Open Group"},"about":{"kicker":"Sobre a OGDI","heading":"Nosso trabalho<br></br>começa <em>antes do lançamento</em>.","models":{"consultoria":{"strong":"Consultoria","rest":"contratada"},"parceria":{"strong":"Parceria","rest":"estratégica"},"societaria":{"strong":"Sócia","rest":"da operação"},"investimento":{"strong":"Investimento","rest":"SCP"}},"body1":"A OGDI (Open Group Desenvolvimento Imobiliário) estrutura e desenvolve empreendimentos imobiliários, e conduz cada operação <em>da conceituação à entrega das chaves</em>.","body2":"Nosso trabalho começa antes da obra: na leitura da oportunidade, na viabilidade, no desenho da operação e na articulação dos parceiros que fazem o projeto avançar.","body3":"Sentamos à mesma mesa de construtoras, incorporadoras, donos de terreno, empresas com ativos e investidores, e conduzimos a operação por dentro: capital, relacionamento com banco, estratégia comercial e o caminho até o lançamento.","body4":"Mais do que desenvolver empreendimentos, <em>transformamos oportunidades em operações prontas para avançar</em>, com potencial, capital e execução alinhados desde a primeira decisão."},"manifesto":{"eyebrow":"Manifesto","thesis":"Muitas oportunidades imobiliárias não fracassam por falta de <em>potencial</em>. Fracassam porque avançam sem <em>estrutura</em> e <keep>por falta de <em>visão</em></keep>.","elaboration":"Uma área promissora, um projeto bem localizado ou uma oportunidade de mercado não se sustentam sozinhos. Sem visão estratégica, viabilidade clara, parceiros certos e condução precisa, o potencial se dispersa antes de virar empreendimento.","bridgeLabel":"O valor nasce antes da obra","bridge":"A Open Group acredita que o valor de um empreendimento nasce <em>antes da obra</em>.","positioning":"Por isso, não tratamos desenvolvimento imobiliário como execução isolada. Tratamos como <em>construção estratégica de valor</em>.","institutional":"Estruturamos e desenvolvemos empreendimentos imobiliários de ponta a ponta, conectando visão, viabilidade, parceiros e operação para transformar oportunidades em projetos prontos para avançar.","closing":"Porque desenvolver bem é decidir melhor desde a origem."},"origem":{"strata":{"01":{"name":"Na leitura correta da oportunidade","desc":"Interpretar o ativo e o potencial real, antes que ele seja óbvio."},"02":{"name":"Na concepção do produto","desc":"Definir o empreendimento certo para aquela oportunidade."},"03":{"name":"Na estruturação da operação","desc":"Alinhar potencial, capital e execução na mesma direção."},"04":{"name":"Na escolha dos parceiros","desc":"Articular parceiros, banco e relacionamento institucional."},"05":{"name":"Na clareza do caminho até o lançamento","desc":"Conduzir com clareza até o projeto estar pronto para avançar."}}},"lideranca":{"kicker":"Quem conduz","heading":"A liderança por trás de cada <em>operação estruturada</em>.","intro":"A OGDI é conduzida por Max Barbosa, que une visão estratégica, domínio da operação e relacionamento institucional. Está à frente de cada operação, de ponta a ponta, para transformar oportunidades em empreendimentos prontos para avançar.","leaders":{"max":{"role":"CEO and Founder","statement":"Antes de desenvolver um empreendimento, é preciso enxergar o <em>valor</em> que ainda não foi revelado.","quote1":"À frente da Open Group, Flying Studio, NID Studio e Rinno Films, conduzo um ecossistema criado para transformar oportunidades imobiliárias em operações mais claras, viáveis e preparadas para avançar.","quote2":"A visão estratégica é onde tudo começa, e dela nascem a formatação do produto, a arquitetura, a tecnologia e experiência no lançamento e a comunicação. Cada empresa, em sua área de genialidade, entrega etapas importantes e alinhadas a resultados."}}},"grupo":{"kicker":"Nosso Grupo","heading":"Nosso Grupo","intro":"Estratégia, arquitetura, tecnologia e audiovisual operam como forças complementares. Cada empresa aprofunda uma etapa da jornada: estruturar, desenhar, antecipar e comunicar.","visitLink":"Visitar site ↗","visitAria":"{name} — visitar site","companies":{"flying":{"role":"Futuros visuais e experiências imersivas","text":"A máquina de antecipar futuros. Imagens e perspectivas 3D, apps, o D.Brave e salas imersivas transportam o cliente para dentro da sua futura realidade — mais de 12 anos traduzindo tijolo e cimento em pura poesia visual.","tags":{"t1":"Perspectivas 3D","t2":"Apps","t3":"D.Brave","t4":"Salas Imersivas"}},"ogdi":{"role":"Estratégia e estruturação","text":"O ponto de partida estratégico. Atuamos com consultoria focada na inteligência de mercado, no desenvolvimento de produtos e na estruturação completa de novos lançamentos desde a sua concepção.","tags":{"t1":"Mercado","t2":"Produto","t3":"Lançamento"}},"nid":{"role":"Arquitetura, interiores e PDV","text":"Onde a inteligência arquitetônica ganha forma e emoção. O lar como um verdadeiro ninho: projetos de interiores, design de fachadas e PDVs concebidos como espaços de aconchego, segurança e forte personalidade.","tags":{"t1":"Interiores","t2":"Fachadas","t3":"PDV"}},"rinno":{"role":"Filmes, movimento e conexão emocional","text":"A produtora audiovisual do grupo. De filmes conceito e de produto a materiais virais e institucionais — dando movimento às histórias e criando a conexão emocional entre o projeto e o seu público.","tags":{"t1":"Filmes","t2":"Viral","t3":"Institucional"}}}},"assinatura":{"kicker":"Mensagem Final","heading":"Transformamos oportunidades em<br></br><em>empreendimentos prontos para morar</em>.","sub":"Vamos juntos...?","ctaProjetos":"Ver os projetos","ctaContato":"Fale com a Open Group"}},"projetos":{"meta":{"title":"Projetos"},"hero":{"breadcrumbHome":"Início","breadcrumbCurrent":"Projetos","kicker":"Projetos · Cases","title":"Empreendimentos","sub":"Da leitura da oportunidade ao lançamento — cada projeto reflete a atuação da Open Group no lançamento."},"filtros":{"aria":"Filtrar projetos","all":"Todos","obra":"Em obra","futuro":"Futuro lançamento","entregue":"Entregue","scp":"Investimento SCP"},"grid":{"noteAll":"Mostrando todos os projetos","noteOne":"{count} projeto · {label}","noteMany":"{count} projetos · {label}"},"cards":{"hits-cupece":{"status":"Em obra","segmento":"Residencial","local":"São Paulo · SP"},"start-park-jabaquara":{"status":"Em obra","segmento":"Residencial","local":"São Paulo · SP"},"oh-freguesia":{"status":"Em obra","segmento":"Residencial","local":"São Paulo · SP"},"hits-santa-catarina":{"status":"Entregue","segmento":"Residencial","local":"São Paulo · SP"},"guarulhos":{"status":"Futuro lançamento","segmento":"Residencial","local":"Guarulhos · SP"},"jabaquara":{"status":"Futuro lançamento","segmento":"Residencial","local":"Jabaquara · SP"}},"scp":{"chip":"Investimento SCP","cta":"Tenho interesse","desc":"Aporte direto na operação por meio de uma SCP — capital que participa do resultado, sem assumir a gestão.","note":"Participação direta no resultado de operações estruturadas, por meio de SCP — capital alocado ao lado da Open Group.","segmento":{"residencial":"Residencial"}},"cta":{"title":"Tem uma área ou projeto com potencial?","text":"Apresente a oportunidade. Fazemos a primeira leitura e indicamos os próximos passos da operação.","ctaLabel":"Apresentar oportunidade"}},"investidores":{"meta":{"title":"Investidores","description":"Capital qualificado entra antes do lançamento — na fase em que o valor é criado. Conheça a tese, o ciclo da operação e os modelos de participação da Open Group."},"rail":{"ariaLabel":"Navegação visual da página investidores","inicio":"Início","tese":"Tese","ciclo":"Ciclo","modelos":"Modelos","governanca":"Governança","operacoes":"Operações","perguntas":"Perguntas","contato":"Contato"},"hero":{"kicker":"Investidores","title":"O valor nasce antes da obra.<br></br>A oportunidade de investir, <em>também</em>.","intro":"A Open Group estrutura operações imobiliárias e abre espaço para capital qualificado entrar antes do lançamento — na fase em que o valor é criado.","scrollHint":"A tese","breadcrumbHome":"Início","breadcrumbCurrent":"Investidores"},"tese":{"items":{"01":{"title":"Entramos <em>antes</em>.","desc":"O valor de um empreendimento é criado na estruturação — leitura da oportunidade, produto e operação — antes de a obra começar."},"02":{"title":"Entendemos o mercado.","desc":"Cada operação nasce de inteligência de mercado e estudo de viabilidade, não de aposta."},"03":{"title":"Conduzimos até o fim.","desc":"Da originação ao lançamento, a mesma condução — e o investidor acompanha cada marco da operação."}}},"ciclo":{"kicker":"O ciclo da operação","intro":"O capital entra na estruturação — e participa da criação de valor, não apenas do resultado.","capitalLabel":"O capital entra aqui","steps":{"10":{"title":"Retorno do Capital Remunerado","desc":"Devolução do capital investido com a remuneração acordada, encerrando o ciclo da operação."},"01":{"title":"Leitura da Oportunidade","desc":"Entendimento do ativo, do estágio e do potencial real de desenvolvimento."},"02":{"title":"Inteligência de Mercado","desc":"Contexto de praça, demanda e leitura concorrencial que fundamenta a tese."},"03":{"title":"EVTL","desc":"Estudo de viabilidade técnica e legal que destrava o caminho da operação."},"04":{"title":"Estruturação Financeira","desc":"Modelagem de capital, fontes de recurso e retorno alinhados ao potencial da operação."},"05":{"title":"Desenvolvimento Imobiliário","desc":"Definição da lógica do produto imobiliário: tipologia, mix e posicionamento."},"06":{"title":"Pré-Lançamento","desc":"Articulação de parceiros e relacionamento com banco, incluindo a CEF quando aplicável."},"07":{"title":"Lançamento","desc":"Entrada no mercado, com produto, narrativa e estratégia comercial prontos."},"08":{"title":"Início de obras","desc":"Largada da execução, com a operação estruturada e os parceiros em campo."},"09":{"title":"Entrega de Chaves","desc":"Conclusão da obra e entrega do empreendimento concluído."}}},"modelos":{"kicker":"Modelos de participação para cada perfil de oportunidade","heading":"Estruturas definidas<br></br>pela operação — não o contrário.","groupSelectorLabel":"Selecionar perfil de oportunidade","groups":{"capital":{"label":"Parcerias e capital","footer":"Cada estrutura é definida caso a caso, conforme a operação.","items":{"scp":{"sigla":"SCP","nome":"Sociedade em Conta de Participação","desc":"O capital participa de uma operação específica, com escopo, papéis e marcos definidos em contrato."},"permuta":{"sigla":"Permuta","nome":"Terreno como capital","desc":"A área entra como capital na operação — o proprietário participa do resultado do empreendimento."},"coinvest":{"sigla":"Coinvest.","nome":"Capital ao lado da operação","desc":"Investimento junto à Open Group e a parceiros estratégicos na estruturação da operação."}}},"desenvolvimento":{"label":"Desenvolvimento e incorporação","footer":"Cada perfil entra na operação a partir do papel que ocupa no desenvolvimento imobiliário.","items":{"incorporadoras":{"sigla":"Incorporadoras","nome":"Oportunidades para desenvolver","desc":"Empresas que buscam novas áreas, composição de parceiros ou operações imobiliárias com potencial de incorporação."},"construtoras":{"sigla":"Construtoras","nome":"Parceria técnica e operacional","desc":"Empresas que podem participar como parceiras técnicas, executoras ou estratégicas em operações estruturadas."},"proprietarios":{"sigla":"Proprietários","nome":"Áreas com potencial imobiliário","desc":"Donos de terrenos ou ativos imobiliários que querem transformar área em operação, participação ou desenvolvimento."}}}}},"governanca":{"kicker":"Governança e acompanhamento","heading":"A operação inteira,<br></br>sob condução única.","intro":"Investir antes da obra exige enxergar a operação. Por isso a Open Group conduz com ordem: marcos definidos, reporte por etapa e uma única responsável do início ao lançamento.","items":{"01":{"title":"Inteligência própria","desc":"Mercado, praça e leitura concorrencial feitos pela equipe — cada recomendação nasce de dado, não de tese genérica."},"02":{"title":"Papéis e marcos definidos","desc":"Escopo, responsabilidades e marcos estabelecidos em contrato, definidos na estruturação da operação."},"03":{"title":"Reporte por etapa","desc":"O investidor recebe o estado da operação a cada etapa vencida: o que avançou, o que vem a seguir e o que mudou no caminho."},"04":{"title":"Condução única","desc":"A condução é da Open Group — da articulação com parceiros e banco à estratégia comercial. Uma só responsável pela operação inteira."},"05":{"title":"Transparência por etapa","desc":"O cliente acompanha o estado da operação a cada etapa vencida: o que avançou, o que vem a seguir e o que mudou no caminho."}}},"operacoes":{"kicker":"A confiança, na prática","heading":"Operações em condução.","intro":"Nosso potencial, capital e execução são guiadas na mesma direção.","prev":"Projeto anterior","next":"Próximo projeto","cta":"Ver todas as operações"},"curva":{"capitalLabel":"O capital entra aqui","stepAria":"Etapa {idx} — {title}"},"perguntas":{"kicker":"Perguntas frequentes","heading":"Investir antes da obra,<br></br>sem letra miúda.","asideText":"Não achou a sua pergunta? <link>Fale com a equipe</link>.","prev":"Perguntas anteriores","next":"Próximas perguntas","items":{"10":{"q":"Qual a diferença entre coinvestir (via SCP/SPE) e um fundo imobiliário (FII)?","a":"O FII é regulado pela CVM, tem cotas em bolsa, gestor profissional e liquidez alta, mas a cota oscila como renda variável. O coinvestimento via SCP/SPE é privado, ilíquido e ligado a um único projeto, com poucos investidores — maior potencial de retorno concentrado, em troca de saída difícil e menos regulação. É o trade-off entre liquidez e regulação, de um lado, e retorno concentrado, de outro."},"11":{"q":"Como recebo o retorno num coinvestimento?","a":"Conforme o contrato do veículo: distribuição de lucros ao longo das vendas ou no encerramento do projeto, em dinheiro ou em unidades. Diferente de um FII, não há distribuição periódica garantida nem cota negociável — o retorno está atrelado ao desempenho daquele empreendimento."},"12":{"q":"Quais os principais riscos do coinvestimento privado?","a":"Iliquidez (é difícil sair antes do fim), dependência da competência e da idoneidade de quem estrutura, risco de execução do projeto e menos transparência que um veículo regulado. Nenhuma estrutura elimina o risco — por isso avaliar quem conduz a operação importa tanto quanto avaliar o imóvel."},"13":{"q":"Por que se diz que o valor é criado antes da obra?","a":"Porque é na estruturação — aprovações, projeto, viabilização do terreno e abertura de vendas — que o empreendimento ganha valor, antes de a obra refletir isso no preço. Quem entra cedo costuma acessar condições abaixo da tabela futura, assumindo parte do risco de desenvolvimento em troca. É retorno por desempenho, não rendimento fixo."},"14":{"q":"Quais os principais riscos de entrar antes da obra?","a":"Atraso de obra, baixa velocidade de vendas, distratos de compradores e — o mais grave no ciclo recente — a saúde financeira da incorporadora: em 2024 o setor liderou os pedidos de recuperação judicial. Qualquer promessa de retorno fixo e garantido deve acender alerta. \"Antes da obra\" não é ganho garantido."},"15":{"q":"Tem liquidez? Consigo sair antes do fim?","a":"A liquidez é baixa. Diferente de um FII com cotas em bolsa, sair de uma SCP ou de um coinvestimento depende de cláusula contratual e de alguém para assumir a sua posição. O melhor é planejar como capital comprometido até o desfecho do projeto — em geral um horizonte de médio a longo prazo (2 a 4 anos ou mais)."},"16":{"q":"O que me protege se a incorporadora tiver problemas?","a":"O principal instrumento é o patrimônio de afetação (Lei 10.931/2004): ele segrega terreno, obra e recebíveis do empreendimento do restante da incorporadora. Em caso de falência, esses bens não entram na massa concursal e a obra pode ser concluída. Verificar se o empreendimento específico tem afetação instituída é item crítico de análise."},"17":{"q":"Que garantias eu posso ter na operação?","a":"Além do patrimônio de afetação, conforme o contrato pode haver garantias reais (hipoteca ou alienação fiduciária do terreno), aval ou fiança dos sócios, cessão fiduciária de recebíveis e cláusulas de preferência. Nenhuma elimina o risco de execução do projeto, mas todas reduzem o risco de perda total."},"18":{"q":"O que checar na due diligence antes de investir?","a":"Matrícula e cadeia dominial do terreno (penhoras, hipotecas, ônus), regularidade urbanística e alvarás, o memorial de incorporação, a instituição do patrimônio de afetação e — o ponto mais subestimado — a saúde financeira e a idoneidade da incorporadora e dos sócios. A prática hoje envolve análise jurídica, de engenharia e contábil. Analise a empresa, não só o imóvel."},"19":{"q":"Como acompanho a operação e a governança?","a":"Por reporte periódico de andamento de obra e de vendas (VGV vendido x orçado), demonstrações contábeis do veículo e movimentação da conta vinculada do projeto. Na SCP, o participante tem direito de fiscalizar, mas não de administrar — e esse direito deve estar expresso em contrato. Falta de transparência é, por si só, um sinal de alerta."},"20":{"q":"Qual o prazo e como o retorno é tributado na minha mão?","a":"O prazo acompanha o ciclo do empreendimento — em geral 2 a 4 anos ou mais, até concluir e liquidar as vendas; não há data fixa garantida. A tributação depende da estrutura: lucros de SCP tendem a ser isentos na sua ponta (havendo lucro contábil), o FII tem isenção própria para pessoa física, e permuta/alienação segue ganho de capital. Confirme sempre com assessoria contábil antes de investir."},"01":{"q":"O que é uma SCP e qual o papel do sócio ostensivo e do participante?","a":"Na Sociedade em Conta de Participação, o sócio ostensivo — em regra a incorporadora — conduz a operação e aparece sozinho perante fornecedores, banco e clientes. O sócio participante (o investidor) aporta capital e divide o resultado conforme sua cota, sem gerir nem aparecer nos contratos. A SCP não tem personalidade jurídica: existe internamente, entre os sócios, regida por contrato."},"02":{"q":"Até onde vai meu risco como sócio participante?","a":"Em regra, sua responsabilidade se limita ao valor aportado — você não responde perante fornecedores, banco ou clientes. Mas o art. 993 do Código Civil é claro: se o participante interfere na gestão externa (assina contratos, negocia com terceiros), passa a responder solidariamente. A proteção é real, desde que o investidor não atue na administração da operação."},"03":{"q":"Como são tributados os lucros que eu recebo de uma SCP?","a":"A SCP é equiparada a pessoa jurídica pela Receita: IRPJ, CSLL, PIS e COFINS são apurados e recolhidos pelo sócio ostensivo. Os lucros distribuídos ao participante costumam ser isentos de IR na sua ponta — mas só quando há lucro contábil formalmente apurado; distribuição sem base pode ser reclassificada como remuneração tributável. SCPs em incorporação ainda podem usar o RET (alíquota unificada de 4%). Confirme sempre com assessoria contábil."},"04":{"q":"A SCP precisa de CNPJ? E como eu recebo o retorno?","a":"Sim — mesmo sem personalidade jurídica, a SCP é obrigada a se inscrever no CNPJ, vinculada ao sócio ostensivo, que responde pelas obrigações acessórias. O retorno segue o contrato: pode ser distribuído ao longo das vendas ou no encerramento, em dinheiro ou em unidades. Os marcos e a forma de distribuição são definidos antes de o capital entrar."},"05":{"q":"Pago imposto ao trocar meu terreno por unidades (permuta física)?","a":"Na permuta física pura — só unidades por unidades, por escritura pública e sem nenhum valor em dinheiro —, a pessoa física não apura ganho de capital; é o caso tradicionalmente isento. A Receita, porém, lê essa isenção de forma restritiva: trocar imóvel residencial por unidades comerciais futuras, por exemplo, foi considerado tributável (Cosit 128/2024). O enquadramento depende do que está na escritura."},"06":{"q":"E se houver \"torna\" (complemento em dinheiro)?","a":"Havendo torna, o imposto incide apenas sobre a parte em dinheiro, com alíquotas de ganho de capital de 15% a 22,5%. A parcela efetivamente trocada por imóvel continua sem incidência. Ou seja: o que tributa é a torna, não a permuta em si."},"07":{"q":"O que é \"permuta financeira\" e por que mudou em 2025?","a":"É quando o dono do terreno, em vez de receber unidades, passa a ter direito a um percentual do faturamento das vendas — só dinheiro. A Solução de Consulta Cosit nº 89/2025 definiu que isso não é permuta, e sim alienação a prazo, integralmente sujeita a ganho de capital (15% a 22,5%) para a pessoa física. Quem estruturou esse arranjo achando que seria isento foi surpreendido — daí a importância de um parecer atualizado."},"08":{"q":"Quando eu recolho o imposto da permuta?","a":"Sobre unidades a construir, o IR do ganho de capital é recolhido até o último dia útil do mês seguinte ao recebimento de cada unidade — não na data da escritura. Na permuta financeira, acompanha o recebimento de cada parcela em dinheiro. Para a incorporadora no RET, a tributação permanece unificada em 4% sobre as receitas."},"09":{"q":"O que é coinvestimento imobiliário?","a":"É reunir o capital de vários investidores para participar de um mesmo empreendimento, dividindo aporte, risco e resultado. Você não detém um imóvel específico, mas uma participação no projeto. Vale a transparência: \"coinvestimento\" descreve a lógica de investir em conjunto — o veículo jurídico concreto costuma ser uma SCP, uma SPE com cotas ou um FII."}}},"cta":{"items":{"capital":{"title":"Tenho capital para investir","desc":"Converse com a equipe sobre as operações em estruturação."},"terreno":{"title":"Tenho um terreno ou ativo","desc":"Apresente a área — fazemos a primeira leitura da oportunidade."}}}},"contato":{"meta":{"title":"Contato","description":"Apresente o ativo, o terreno ou o projeto. A Open Group faz a primeira leitura da oportunidade e retorna com os próximos passos."},"hero":{"kicker":"Contato","title":"Toda oportunidade começa com <em>uma conversa</em>.","intro":"Apresente o ativo, o terreno ou o projeto. A Open Group faz a primeira leitura da oportunidade e retorna com os próximos passos.","canais":{"email":{"label":"E-mail","hint":"Para apresentações de oportunidade e material de projeto"},"whatsapp":{"label":"WhatsApp / Telefone","hint":"Conversa direta com a equipe"},"localizacao":{"label":"Localização","hint":"Atuação em desenvolvimento imobiliário"}},"breadcrumbHome":"Início","breadcrumbCurrent":"Contato"},"conversa":{"kicker":"Como conduzimos","heading":"Do primeiro contato<br></br>aos próximos passos.","etapas":{"01":{"title":"Primeira leitura","desc":"A equipe avalia o material recebido — potencial, localização e aderência à estratégia de desenvolvimento."},"02":{"title":"Conversa estratégica","desc":"Uma conversa direta para entender objetivos, prazos e o estágio do projeto ou do ativo."},"03":{"title":"Caminho de estruturação","desc":"Indicamos o formato possível de atuação — da viabilidade à condução até o lançamento."}}},"info":{"kicker":"Vamos conversar","heading":"Apresente sua oportunidade.","body":"Conte sobre o ativo, o terreno ou o projeto. Fazemos a primeira leitura da oportunidade e indicamos os próximos passos possíveis.","itens":{"email":"E-mail","whatsapp":"WhatsApp / Telefone","localizacao":"Localização"}},"form":{"aria":"Formulário de contato","labels":{"nome":"Nome","empresa":"Empresa","email":"E-mail","whatsapp":"WhatsApp","tipo":"Tipo de contato","mensagem":"Mensagem"},"placeholders":{"nome":"Seu nome completo","empresa":"Empresa ou fundo","email":"voce@empresa.com","whatsapp":"+55 11 90000-0000","mensagem":"Tipo de ativo, localização, estágio do projeto…"},"tipos":{"oportunidade":"Apresentar oportunidade","projeto":"Falar sobre projeto","parceria":"Parceria","investimento":"Investimento","imprensa":"Imprensa","outro":"Outro"},"submit":"Enviar mensagem","consent":"Ao enviar, você concorda em ser contatado pela equipe da OGDI.","sucesso":{"title":"Mensagem recebida.","body":"A equipe da Open Group faz a primeira leitura e retorna com os próximos passos."}}},"insights":{"kicker":"Insights","title":"Análises e inteligência de mercado.","meta":{"title":"Insights"}},"parceiros":{"kicker":"Parceiros","title":"Ecossistema de parceiros.","meta":{"title":"Parceiros"}},"privacidade":{"meta":{"title":"Política de Privacidade","description":"Como a Open Group coleta, utiliza, armazena e protege dados pessoais, em conformidade com a LGPD (Lei nº 13.709/2018)."},"kicker":"Documento institucional","title":"Política de Privacidade","updatedLabel":"Última atualização","updated":"Junho de 2026","intro":"A privacidade e a proteção de dados pessoais fazem parte do compromisso de condução responsável da Open Group. Este documento explica, de forma transparente, como tratamos os dados de quem navega neste site e de quem se relaciona com a nossa equipe.","sections":{"s1":{"heading":"Objetivo e abrangência","paras":["Esta Política de Privacidade descreve como a Open Group — Desenvolvimento Imobiliário (“Open Group”) coleta, utiliza, armazena, compartilha e protege dados pessoais de visitantes deste site e de pessoas que entram em contato com a equipe, em conformidade com a Lei Geral de Proteção de Dados Pessoais — LGPD (Lei nº 13.709/2018).","Ela se aplica exclusivamente a este site institucional e aos canais de contato aqui disponibilizados. Sites de terceiros eventualmente vinculados (como páginas de parceiros e plataformas de mapas) possuem políticas próprias, que recomendamos consultar."]},"s2":{"heading":"Dados que coletamos","paras":["Tratamos duas categorias de dados pessoais:"],"list":["Dados fornecidos por você — ao utilizar o formulário de contato ou os canais diretos (e-mail e telefone), coletamos as informações que você decide compartilhar: nome, empresa ou fundo, e-mail, WhatsApp/telefone, tipo de contato e o conteúdo da mensagem, que pode incluir informações sobre ativos, terrenos ou projetos.","Dados coletados automaticamente — informações técnicas de navegação, como endereço IP, tipo de navegador, dispositivo, páginas visitadas e tempo de permanência, coletadas por meio de cookies e tecnologias semelhantes."],"parasAfter":["Não coletamos, neste site, dados pessoais sensíveis (como dados de saúde, biometria ou convicções), e nossos serviços não se destinam a menores de 18 anos."]},"s3":{"heading":"Finalidades e bases legais","paras":["Utilizamos os dados pessoais para as seguintes finalidades, sempre amparadas em uma base legal da LGPD:"],"list":["Responder ao seu contato e conduzir a primeira leitura da oportunidade apresentada — base legal: procedimentos preliminares a contrato (art. 7º, V) e legítimo interesse (art. 7º, IX);","Manter o relacionamento institucional e comercial decorrente do contato — base legal: legítimo interesse;","Cumprir obrigações legais ou regulatórias e exercer direitos em processos — base legal: cumprimento de obrigação legal (art. 7º, II) e exercício regular de direitos (art. 7º, VI);","Analisar o uso do site e aprimorar a experiência de navegação — base legal: consentimento (art. 7º, I) e legítimo interesse."]},"s4":{"heading":"Cookies e tecnologias de navegação","paras":["Cookies são pequenos arquivos armazenados no seu navegador. Utilizamos cookies estritamente necessários ao funcionamento do site e, quando aplicável, cookies analíticos para entender como o site é utilizado.","Você pode gerenciar ou desativar cookies nas configurações do seu navegador. A desativação de cookies necessários pode afetar o funcionamento de partes do site."]},"s5":{"heading":"Compartilhamento de dados","paras":["A Open Group não vende dados pessoais. O compartilhamento ocorre apenas nas seguintes hipóteses:"],"list":["Com prestadores de serviço que operam o site e os canais de comunicação (hospedagem, e-mail, ferramentas de análise), limitado ao necessário para a prestação do serviço;","Com parceiros da operação imobiliária, quando o seu contato tiver por objetivo uma oportunidade que demande essa articulação — sempre no contexto da finalidade original;","Com autoridades públicas, mediante obrigação legal, regulatória ou ordem judicial;","Em operações societárias (como fusão ou aquisição), caso em que o titular será informado sobre a mudança de controlador."]},"s6":{"heading":"Armazenamento e prazo de retenção","paras":["Os dados são armazenados em ambientes controlados, podendo estar hospedados em servidores localizados fora do Brasil — nesse caso, a transferência internacional observa o disposto nos arts. 33 e seguintes da LGPD.","Mantemos os dados pelo tempo necessário ao cumprimento das finalidades desta política: dados de contato são retidos enquanto durar o relacionamento ou a tratativa, e após isso pelo prazo necessário ao cumprimento de obrigações legais e ao exercício regular de direitos. Encerrados os prazos, os dados são eliminados ou anonimizados."]},"s7":{"heading":"Segurança das informações","paras":["Adotamos medidas técnicas e administrativas razoáveis para proteger os dados pessoais contra acessos não autorizados, perda, alteração ou divulgação indevida — incluindo criptografia em trânsito (HTTPS), controle de acesso e minimização de coleta.","Nenhum sistema é absolutamente seguro. Caso identifiquemos incidente de segurança que possa acarretar risco ou dano relevante aos titulares, comunicaremos os afetados e a Autoridade Nacional de Proteção de Dados (ANPD), na forma da lei."]},"s8":{"heading":"Direitos dos titulares","paras":["Nos termos do art. 18 da LGPD, você pode solicitar, a qualquer momento:"],"list":["Confirmação da existência de tratamento dos seus dados;","Acesso aos dados que mantemos sobre você;","Correção de dados incompletos, inexatos ou desatualizados;","Anonimização, bloqueio ou eliminação de dados desnecessários, excessivos ou tratados em desconformidade com a lei;","Portabilidade dos dados a outro fornecedor, observados os regulamentos da ANPD;","Eliminação dos dados tratados com base no seu consentimento;","Informação sobre as entidades com as quais compartilhamos seus dados;","Revogação do consentimento, quando esta for a base legal do tratamento."],"parasAfter":["As solicitações são gratuitas e serão respondidas nos prazos previstos na legislação. Para exercê-las, utilize o canal indicado na seção seguinte."]},"s9":{"heading":"Encarregado e canal de contato","paras":["As solicitações relativas a dados pessoais devem ser encaminhadas ao encarregado pelo tratamento de dados pessoais da Open Group pelo e-mail {email}, com o assunto “Privacidade de dados”. Se preferir, utilize a página de contato deste site."]},"s10":{"heading":"Legislação aplicável","paras":["Esta política é regida pelas leis da República Federativa do Brasil, em especial a Lei nº 13.709/2018 (LGPD) e o Marco Civil da Internet (Lei nº 12.965/2014). Fica eleito o foro da comarca de São Paulo/SP para dirimir eventuais controvérsias."]},"s11":{"heading":"Atualizações desta política","paras":["Esta política pode ser atualizada a qualquer momento para refletir mudanças legais, regulatórias ou operacionais. A versão vigente estará sempre disponível nesta página, com a data de atualização indicada no topo. Alterações relevantes poderão ser comunicadas pelos canais de contato informados."]}},"contact":{"text":"Dúvidas sobre esta política? Escreva para <email></email> ou acesse a <link>página de contato</link>."}},"empreendimento":{"hero":{"breadcrumbAria":"Trilha de navegação","home":"Início","projetos":"Projetos","badgeSuffix":"Empreendimento","venturePartner":"OGDI sócia da operação","scrollCue":"Role","cta":"Conheça o empreendimento","ctaContato":"Falar com a equipe"},"nav":{"ariaLabel":"Seções do empreendimento","sobre":"Sobre o projeto","ficha":"Ficha técnica","lazer":"Lazer","galeria":"Galeria","tour":"Tour virtual","obra":"Evolução da obra","localizacao":"Localização"},"sobre":{"kicker":"Sobre o projeto","mediaTag":"render · fachada"},"lazer":{"kicker":"Lazer & diferenciais","heading":"Áreas comuns completas."},"info":{"kicker":"O empreendimento","heading":"Da leitura da oportunidade à condução até o lançamento.","labels":{"status":"Status","segmento":"Segmento","localizacao":"Localização","regiao":"Região","atuacao":"Atuação Open Group","modelo":"Modelo","tipologia":"Tipologia · metragem"},"venturePartner":"Sócia da operação","tbc":"A confirmar","cta":"Tenho interesse"},"gallery":{"aria":"Galeria de imagens","kicker":"Galeria","disclaimer":"Perspectiva meramente ilustrativa","showMore":"Mostrar mais imagens","showLess":"Mostrar menos","count":"{count, plural, one {# imagem} other {# imagens}}","filters":{"todas":"Todas","comuns":"Áreas comuns","decorado":"Decorado","plantas":"Plantas","implant":"Implantação"}},"quote":{"text":"Um endereço pensado para <em>elevar o dia a dia</em> — onde localização, conforto e o bom uso de cada metro se encontram."},"tour":{"kicker":"Experiência","heading":"Conheça todos os detalhes","virtual":{"kind":"Tour virtual 360°","title":"Caminhe pelo decorado","text":"Percorra os ambientes do apartamento decorado e as áreas comuns em 360°, no seu ritmo — de qualquer dispositivo.","meta":["Navegação livre","Desktop e mobile"],"cue":"Abrir tour 360°"},"video":{"kind":"Vídeo do empreendimento","title":"O conceito em movimento","text":"Um filme curto que apresenta a proposta, a arquitetura e a localização do {name}.","meta":["Duração ~2 min","Produção audiovisual"],"cue":"Assistir ao vídeo"}},"obra":{"kicker":"Andamento","heading":"Acompanhe a evolução da obra","overall":"Avanço geral da obra","photoLabel":"Registro {n}","stages":["Terraplenagem","Fundações e contenções","Estrutura","Vedação / alvenaria","Instalações elétricas / hidráulicas","Revestimentos internos","Fachada","Acabamento e limpeza"]},"atuacao":{"kicker":"A atuação da Open Group","heading":"Como estruturamos esta operação."},"neighborhood":{"kicker":"Entorno do empreendimento","fallbackTitle":"Localização em definição","fallbackText":"A localização deste empreendimento ainda será detalhada. Quando o endereço for confirmado, este bloco passa a exibir o mapa interativo do Google Maps.","fallbackAddress":"Endereço em definição","mapUnavailable":"Mapa indisponível","addressTbd":"Endereço em definição.","placeholderText":"Este espaço já segue o padrão da página e será ativado com Google Maps assim que a localização for informada.","mapTitle":"Google Maps - {name}","near":"perto de","filters":[{"key":"empreendimento","label":"Empreendimento"},{"key":"educacao","label":"Educação","q":"escolas"},{"key":"comercio","label":"Comércio & gastronomia","q":"restaurantes e comércio"},{"key":"saude","label":"Saúde","q":"hospitais e farmácias"},{"key":"mobilidade","label":"Mobilidade","q":"estações de metrô e ônibus"},{"key":"lazer","label":"Lazer","q":"parques e praças"}]},"proximos":{"kicker":"Continue explorando","heading":"Outros empreendimentos.","link":"Ver todos os projetos"},"cta":{"title":"Interesse no {name}?","text":"Fale com a equipe da Open Group e receba mais informações sobre o empreendimento e a operação.","ctaLabel":"Falar com a equipe"}},"atuacao":{"kicker":"Atuação","title":"O que a Open Group faz.","meta":{"title":"Atuação"}},"proj":{"hits-cupece":{"card":{"status":"Em obra","segmento":"Residencial","local":"São Paulo · SP"},"heroSummary":"Um empreendimento residencial no Cupecê, em uma região conectada, conveniente e em valorização, na zona sul de São Paulo.","intro":["O Hits Cupecê nasce de uma leitura objetiva do território: na Rua Dom João Soares Coelho, 220, na Vila Império, uma região em ascensão da zona sul, com comércio forte e conveniências que sustentam demanda real por moradia.","Em um terreno de 2.090,22 m², uma única torre de 13 pavimentos reúne 196 unidades: studios de 24 m² e apartamentos de 2 dormitórios de 37 a 38 m² com terraço com churrasqueira a carvão, além de gardens maiores. São quatro elevadores, projeto arquitetônico de Danilo Penna e um lazer completo, com CineOpen, piscinas e praça da fogueira."],"facts":["Em obra","Studio e 2 dormitórios","Terraço com churrasqueira","Cupecê - São Paulo"],"ficha":[{"value":"Studio e 2 dormitórios","label":"Tipologias"},{"value":"24 a 79 m²","label":"Metragem"},{"value":"13 pavimentos","label":"Pavimentos"},{"value":"196 unidades","label":"Unidades"},{"value":"0 carro\n23 moto","label":"Vagas"},{"value":"Terraço com churrasqueira a carvão","label":"Diferencial"},{"value":"Caixa Econômica","label":"Financiamento"},{"value":"MCMV","label":"Programa"},{"value":"TS Engenharia","label":"Construtora"},{"value":"Em obras","label":"Entrega","tbd":true}],"lazer":{"lead":"Mais de duas dezenas de itens de lazer e conveniência distribuídos do subsolo ao 5º pavimento.","feat":{"kicker":"Destaque","title":"CineOpen"},"items":[{"icon":"pool","label":"Piscina adulto"},{"icon":"pool","label":"Piscina infantil"},{"icon":"gym","label":"Fitness"},{"icon":"sport","label":"Crossfit"},{"icon":"beach","label":"Beach sports"},{"icon":"cowork","label":"Beach work"},{"icon":"sport","label":"Ladder sport"},{"icon":"basket","label":"Streetball"},{"icon":"gym","label":"Alongamento"},{"icon":"play","label":"Playground"},{"icon":"toys","label":"Brinquedoteca"},{"icon":"game","label":"Espaço teen"},{"icon":"chess","label":"Big chess"},{"icon":"gazebo","label":"Gazebo"},{"icon":"pet","label":"Pet place"},{"icon":"fire","label":"Praça da fogueira"},{"icon":"bbq","label":"Churrasqueira"},{"icon":"herb","label":"Mini-horta"},{"icon":"gourmet","label":"Espaço gourmet"},{"icon":"lounge","label":"Salão de festas"},{"icon":"cowork","label":"Coworking"},{"icon":"laundry","label":"Lavanderia"},{"icon":"bike","label":"Bike share"},{"icon":"roof","label":"Sky lounge"}]},"locationStory":{"kicker":"A tese do lugar","title":"Antes da obra, existe a leitura do território.","body":["Localizado na Rua Dom João Soares Coelho, o Hits Cupecê está inserido em uma região em plena ascensão e valorização, com comércio forte e conveniências que simplificam a rotina.","A proximidade com a Avenida Cupecê amplia essa leitura. Com 5,3 km de extensão, ela conecta a Ponte do Morumbi, na Marginal Pinheiros, ao centro de Diadema, criando um eixo relevante de mobilidade na zona sul.","A poucos minutos da Rodovia dos Imigrantes, o endereço também aproxima a cidade do litoral sul. Para a OGDI, essa combinação de acesso, vida cotidiana e valorização transforma a localização em tese de produto."],"highlights":[{"title":"Região em ascensão","text":"Um entorno com valorização, comércio e serviços que reforçam a consistência da demanda."},{"title":"Conexões urbanas","text":"Avenida Cupecê, Marginal Pinheiros, Diadema e Rodovia dos Imigrantes no raio estratégico do projeto."},{"title":"Cotidiano conveniente","text":"Facilidade de acesso e conveniências próximas para reduzir deslocamentos e dar fluidez à rotina."}]},"productStory":{"kicker":"O produto como resposta","title":"Plantas inteligentes pensadas para uma vida urbana mais prática.","body":["As unidades de studio e 2 dormitórios respondem a um público que busca morar bem, com eficiência e conexão com a cidade.","O terraço com churrasqueira adiciona uma camada de uso e desejo ao produto: um espaço privado para receber, respirar e ampliar a experiência do apartamento."],"cards":[{"label":"Tipologia","value":"Studio e 2 dormitórios","text":"Configurações alinhadas a diferentes momentos de vida e perfis de moradia."},{"label":"Endereço","value":"Rua Dom João Soares Coelho","text":"Implantação em uma área de conveniência e valorização no Cupecê."},{"label":"Mobilidade","value":"Eixo Avenida Cupecê","text":"Conexão com Marginal Pinheiros, Diadema e Rodovia dos Imigrantes."},{"label":"Experiência","value":"Terraço com churrasqueira","text":"Um diferencial que transforma a área privativa em lugar de encontro."}]},"galleryIntro":{"kicker":"Do conceito à experiência","title":"A narrativa também aparece nos espaços.","body":["A galeria apresenta ambientes que traduzem a proposta do Hits Cupecê: morar com praticidade, áreas de uso bem definidas e uma rotina conectada ao entorno."]},"strategyStory":{"kicker":"Estruturação OGDI","title":"A operação foi pensada antes de a obra chegar ao canteiro.","body":["No Hits Cupecê, a OGDI atua na etapa em que o valor é construído com mais precisão: leitura da oportunidade, definição de produto, análise de viabilidade, articulação de parceiros e condução até a fase de obra.","Essa inteligência transforma uma localização promissora em uma operação estruturada, com produto, mercado e execução caminhando na mesma direção."]},"obra":{"reference":"Atualizado em maio de 2026","stages":["Serviços preliminares gerais","Fundações e contenções","Supraestrutura","Paredes e painéis","Coberturas e proteções","Revestimentos","Pavimentação","Instalações","Complementações","Infraestrutura e urbanização"]},"closingStatement":{"title":"Cupecê não é apenas um endereço.","text":"É uma operação estruturada a partir de localização, demanda e visão de produto.","ctaLabel":"Tenho interesse no empreendimento"}},"start-park-jabaquara":{"card":{"status":"Em obra","segmento":"Residencial","local":"São Paulo · SP"},"heroSummary":"Um empreendimento residencial em obra no Parque Jabaquara, na zona sul de São Paulo, conectado a Congonhas e ao futuro monotrilho.","intro":["O Start Park Jabaquara nasce no Parque Jabaquara, na zona sul de São Paulo, uma região conectada e em valorização, a poucos minutos do Aeroporto de Congonhas e na rota do futuro monotrilho. O empreendimento ocupa um terreno de 1.078,80 m² na Rua Alba, 570.","Em uma única torre de 18 pavimentos, são 153 apartamentos de 1 e 2 dormitórios de 30 a 52 m², todos com terraço com churrasqueira, incluindo opções garden. O empreendimento tem dois elevadores, lazer completo (Cine Open Air, piscina, beach sports, crossfit, praça do fogo) e soluções sustentáveis, como recarga de bike elétrica, preparação para energia solar e elevadores inteligentes."],"facts":["Em obra","1 e 2 dormitórios","Terraço com churrasqueira","Parque Jabaquara - SP"],"ficha":[{"value":"1 e 2 dormitórios","label":"Tipologias"},{"value":"30 a 52 m²","label":"Metragem"},{"value":"18 pavimentos","label":"Pavimentos"},{"value":"153 unidades","label":"Unidades"},{"value":"Sem vaga de carro","label":"Vagas"},{"value":"Terraço com churrasqueira","label":"Diferencial"},{"value":"Caixa Econômica","label":"Financiamento"},{"value":"MCMV","label":"Programa"},{"value":"TS Engenharia","label":"Construtora"},{"value":"Em obras","label":"Entrega","tbd":true}],"lazer":{"lead":"Mais de duas dezenas de itens de lazer e conveniência, distribuídos no subsolo e no térreo.","feat":{"kicker":"Destaque","title":"CineOpen"},"items":[{"icon":"pool","label":"Piscina"},{"icon":"roof","label":"Solarium"},{"icon":"gazebo","label":"Redário"},{"icon":"play","label":"Play aventura"},{"icon":"toys","label":"Acampamento kids"},{"icon":"sport","label":"Crossfit"},{"icon":"gym","label":"Fitness"},{"icon":"play","label":"Play baby"},{"icon":"toys","label":"Brinquedoteca"},{"icon":"herb","label":"Horta"},{"icon":"bbq","label":"Churrasqueira"},{"icon":"lounge","label":"Salão de festas"},{"icon":"sport","label":"Ladder sport"},{"icon":"market","label":"Mini market"},{"icon":"beach","label":"Beach sports"},{"icon":"beach","label":"Beach lounge"},{"icon":"basket","label":"Basquete"},{"icon":"bike","label":"Bike station"},{"icon":"pet","label":"Pet place"},{"icon":"fire","label":"Praça do fogo"}]},"locationStory":{"kicker":"A tese do lugar","title":"No Jabaquara, a oportunidade nasce da leitura da praça.","body":["Na Rua Alba, no Parque Jabaquara, o Start Park está inserido em uma região conectada e em valorização, com comércio, serviços e forte oferta de transporte na zona sul de São Paulo.","O endereço fica a poucos minutos do Aeroporto de Congonhas e na rota do futuro monotrilho, com acesso às avenidas Santa Catarina, Cupecê, Roberto Marinho, Washington Luís, Bandeirantes e Imigrantes.","Para a OGDI, essa combinação de mobilidade, vida cotidiana e valorização transforma a localização em tese de produto."],"highlights":[{"title":"Mobilidade ampla","text":"Próximo a Congonhas e ao futuro monotrilho, com acesso a Imigrantes, Bandeirantes e Washington Luís."},{"title":"Região em valorização","text":"Entorno com comércio e serviços que sustentam a demanda residencial."},{"title":"Origem estruturada","text":"A oportunidade foi organizada antes da execução, com produto e operação alinhados."}]},"productStory":{"kicker":"O produto como resposta","title":"Plantas inteligentes pensadas para uma vida urbana mais prática.","body":["As unidades de 1 e 2 dormitórios respondem a um público que busca morar bem, com eficiência e conexão com a cidade.","O terraço com churrasqueira e um lazer completo ampliam o uso do empreendimento no dia a dia."],"cards":[{"label":"Tipologia","value":"1 e 2 dormitórios","text":"Plantas eficientes, alinhadas a diferentes perfis de moradia urbana."},{"label":"Endereço","value":"Rua Alba, 570","text":"Parque Jabaquara, zona sul de São Paulo, próximo a Congonhas e ao futuro monotrilho."},{"label":"Mobilidade","value":"Eixo Santa Catarina · Cupecê","text":"Acesso a Roberto Marinho, Washington Luís, Bandeirantes e Imigrantes."},{"label":"Experiência","value":"Lazer completo","text":"Piscina, fitness, crossfit, cine aberto, bike station e salão de festas gourmet."}]},"galleryIntro":{"kicker":"Do conceito à experiência","title":"A narrativa também aparece nos espaços.","body":["As imagens do Start Park Jabaquara funcionam como continuidade da narrativa: produto, implantação e percepção de valor ganham forma visual."]},"strategyStory":{"kicker":"Estruturação OGDI","title":"A operação foi organizada antes de chegar ao canteiro.","body":["No Start Park Jabaquara, a OGDI conectou leitura da oportunidade, conceituação do produto, modelagem da operação e articulação dos parceiros necessários.","O resultado é um empreendimento em obra com uma tese construída antes da execução, reduzindo improviso e dando clareza ao processo."]},"obra":{"reference":"Atualizado em maio de 2026","stages":["Serviços preliminares gerais","Fundações e contenções","Supraestrutura","Paredes e painéis","Coberturas e proteções","Revestimentos","Pavimentação","Instalações","Complementações","Infraestrutura e urbanização"]},"closingStatement":{"title":"Start Park Jabaquara é resultado de estruturação.","text":"Uma operação que saiu da leitura de mercado para a obra com produto, parceiros e execução alinhados.","ctaLabel":"Tenho interesse no empreendimento"}},"oh-freguesia":{"card":{"status":"Em obra","segmento":"Residencial","local":"São Paulo · SP"},"heroSummary":"Um empreendimento residencial em obra na Freguesia do Ó, na zona norte de São Paulo, com lazer completo e Varanda Grill.","intro":["O Oh Freguesia nasce na Freguesia do Ó, na zona norte de São Paulo, um dos bairros mais antigos da capital, com vida de bairro consolidada, comércio e serviços no entorno. O empreendimento ocupa um terreno de 600 m² na Rua Homero Francisco Terra, 50.","Em uma única torre de térreo + 16 pavimentos, são 90 apartamentos de 1 e 2 dormitórios de 32 a 44 m², todos com varanda grill, além de uma loja no térreo. O empreendimento tem dois elevadores, lazer de clube (Cine Open Air, Sky Lounge, Aquaplay, Crossfit, Beach Sports) e soluções sustentáveis, como recarga de bike elétrica, preparação para energia solar e elevadores inteligentes."],"facts":["Em obra","1 e 2 dormitórios","Varanda Grill","Freguesia do Ó - SP"],"ficha":[{"value":"1 e 2 dormitórios","label":"Tipologias"},{"value":"32 a 44 m²","label":"Metragem"},{"value":"Térreo + 16","label":"Pavimentos"},{"value":"90 unidades","label":"Unidades"},{"value":"1 vaga PNE","label":"Vagas"},{"value":"Varanda Grill","label":"Diferencial"},{"value":"Caixa Econômica","label":"Financiamento"},{"value":"MCMV","label":"Programa"},{"value":"TS Engenharia","label":"Construtora"},{"value":"Em obras","label":"Entrega","tbd":true}],"lazer":{"lead":"Mais de uma dezena de itens de lazer e conveniência distribuídos do térreo à cobertura.","feat":{"kicker":"Destaque","title":"CineOpen"},"items":[{"icon":"fire","label":"Praça do fogo"},{"icon":"pet","label":"Pet place"},{"icon":"market","label":"Grab & Go"},{"icon":"sport","label":"Ladder sport"},{"icon":"bike","label":"Bicicletário"},{"icon":"hall","label":"Hall social"},{"icon":"gourmet","label":"Espaço gourmet"},{"icon":"gym","label":"Fitness"},{"icon":"sport","label":"Crossfit"},{"icon":"lounge","label":"Espaço família"},{"icon":"roof","label":"Sky lounge"},{"icon":"play","label":"Playground"},{"icon":"pool","label":"Aquaplay"},{"icon":"beach","label":"Beach sports"}]},"locationStory":{"kicker":"A tese do lugar","title":"Na Freguesia do Ó, um bairro consolidado vira tese.","body":["Na Rua Homero Francisco Terra, o Oh Freguesia está inserido em um dos bairros mais antigos de São Paulo, com vida de bairro consolidada, comércio e serviços no entorno.","A Freguesia do Ó combina identidade urbana estabelecida e demanda residencial constante na zona norte da capital.","Para a OGDI, esse contexto de bairro consolidado sustenta produto e operação, transformando a localização em tese."],"highlights":[{"title":"Bairro consolidado","text":"Um dos endereços mais tradicionais da zona norte, com vida de bairro estabelecida."},{"title":"Demanda constante","text":"Comércio, serviços e infraestrutura urbana que sustentam a procura por moradia."},{"title":"Operação consolidada","text":"Produto, parceiros e execução conectados para viabilizar o avanço da obra."}]},"productStory":{"kicker":"O produto como resposta","title":"Plantas inteligentes pensadas para uma vida urbana mais prática.","body":["As unidades de 1 e 2 dormitórios respondem à demanda urbana da Freguesia do Ó, com eficiência e conexão com a cidade.","A Varanda Grill e um conjunto de lazer amplo ampliam a experiência do morar no dia a dia."],"cards":[{"label":"Tipologia","value":"1 e 2 dormitórios","text":"Plantas eficientes para diferentes perfis de moradia urbana."},{"label":"Endereço","value":"Rua Homero Francisco Terra","text":"Freguesia do Ó, zona norte de São Paulo."},{"label":"Lazer","value":"Beach club e sky lounge","text":"Aqua play, crossfit, cinema open, praça do fogo, pet place e playground."},{"label":"Experiência","value":"Varanda Grill","text":"A área privativa vira espaço de uso e convívio."}]},"galleryIntro":{"kicker":"Do conceito à experiência","title":"A narrativa também aparece nos espaços.","body":["A galeria do Oh Freguesia apresenta a materialização da operação: conceito, produto e percepção de valor organizados em uma experiência visual."]},"strategyStory":{"kicker":"Estruturação OGDI","title":"O valor foi construído antes do início da execução.","body":["No Oh Freguesia, a OGDI conduziu a leitura do ativo, a conceituação do produto e a articulação dos parceiros necessários para consolidar a operação.","A obra é consequência desse trabalho anterior: uma sequência de decisões que deu forma, viabilidade e direção ao empreendimento."]},"obra":{"reference":"Posição em maio de 2026","stages":["Serviços preliminares gerais","Fundações e contenções","Supraestrutura","Paredes e painéis","Coberturas e proteções","Revestimentos","Pavimentação","Instalações","Complementações","Infraestrutura e urbanização"]},"closingStatement":{"title":"Oh Freguesia traduz potencial em operação.","text":"Um empreendimento que nasce da inteligência de mercado e avança com produto e execução conectados.","ctaLabel":"Tenho interesse no empreendimento"}},"guarulhos":{"card":{"status":"Futuro lançamento","segmento":"Residencial","local":"Guarulhos · SP"},"heroSummary":"Um futuro lançamento residencial em Guarulhos, em fase de estruturação de oportunidade, produto e viabilidade.","intro":["A oportunidade em Guarulhos foi originada pela Open Group com base em leitura de mercado local e avaliação criteriosa do potencial de desenvolvimento da área.","A operação está em estruturação: viabilidade em análise, parceiros sendo articulados e modelagem financeira em curso para alinhar capital e execução."],"facts":["Futuro lançamento","Residencial","Guarulhos - SP","Sócia da operação"],"ficha":[{"value":"A definir","label":"Tipologias","tbd":true},{"value":"A definir","label":"Metragem","tbd":true},{"value":"A definir","label":"Pavimentos","tbd":true},{"value":"A definir","label":"Unidades","tbd":true},{"value":"A definir","label":"Vagas","tbd":true},{"value":"A definir","label":"Diferencial","tbd":true},{"value":"A definir","label":"Financiamento","tbd":true},{"value":"A definir","label":"Programa","tbd":true},{"value":"A definir","label":"Construtora","tbd":true},{"value":"A definir","label":"Entrega","tbd":true}],"lazer":{"lead":"Mais de uma dezena de itens de lazer e conveniência distribuídos do térreo à cobertura.","feat":{"kicker":"Destaque","title":"CineOpen"},"items":[{"icon":"pool","label":"Piscina"},{"icon":"gym","label":"Academia"},{"icon":"cowork","label":"Coworking"},{"icon":"gourmet","label":"Espaço gourmet"},{"icon":"bbq","label":"Churrasqueira"},{"icon":"pet","label":"Pet place"},{"icon":"play","label":"Playground"},{"icon":"laundry","label":"Lavanderia"},{"icon":"bike","label":"Bicicletário"},{"icon":"market","label":"Mini market"},{"icon":"lounge","label":"Salão de festas"},{"icon":"roof","label":"Rooftop"}]},"locationStory":{"kicker":"A tese do lugar","title":"Em Guarulhos, a leitura da oportunidade vem antes do lançamento.","body":["O projeto em Guarulhos está em fase de estruturação a partir de uma leitura de mercado local e do potencial de desenvolvimento da área.","Antes de comunicar produto ou lançamento, a Open Group organiza as variáveis que sustentam a operação: território, demanda, viabilidade e parceiros.","Essa etapa inicial é decisiva para transformar uma oportunidade imobiliária em um empreendimento com direção clara."],"highlights":[{"title":"Mercado local","text":"Leitura da praça e do potencial de absorção antes da definição final do produto."},{"title":"Viabilidade em curso","text":"Análise técnica, financeira e estratégica para sustentar a evolução da operação."},{"title":"Estruturação inicial","text":"Articulação de parceiros e desenho de caminho antes do compromisso de lançamento."}]},"productStory":{"kicker":"O produto como resposta","title":"Plantas inteligentes pensadas para uma vida urbana mais prática.","body":["Em Guarulhos, a Open Group conduz a etapa em que o produto ainda está sendo calibrado a partir da oportunidade.","A definição de posicionamento, mix e estratégia comercial deve nascer da consistência entre território, demanda e execução possível."],"cards":[{"label":"Status","value":"Futuro lançamento","text":"Projeto em estruturação, ainda antes da comunicação final de mercado."},{"label":"Segmento","value":"Residencial","text":"Direção de produto voltada à moradia e ao potencial local."},{"label":"Localização","value":"Guarulhos","text":"Praça em análise para definição de posicionamento e viabilidade."},{"label":"Modelo","value":"Sócia da operação","text":"Operação construída com alinhamento entre capital, parceiros e execução."}]},"galleryIntro":{"kicker":"Do estudo à materialização","title":"A narrativa também aparece nos espaços.","body":["Enquanto o produto avança, a galeria mantém a estrutura visual da página e será atualizada com imagens, renders ou materiais oficiais do empreendimento."]},"strategyStory":{"kicker":"Estruturação Open Group","title":"A operação está sendo desenhada antes de chegar ao mercado.","body":["No projeto Guarulhos, a Open Group atua na origem: leitura da oportunidade, análise de viabilidade, modelagem financeira e articulação dos parceiros necessários.","O objetivo é preparar a operação com clareza antes do lançamento, evitando decisões desconectadas entre produto, mercado e execução."]},"closingStatement":{"title":"Guarulhos ainda está em estruturação.","text":"Um projeto em desenvolvimento, conduzido com método para transformar potencial em operação viável.","ctaLabel":"Tenho interesse no empreendimento"}},"jabaquara":{"card":{"status":"Futuro lançamento","segmento":"Residencial","local":"Jabaquara · SP"},"heroSummary":"Um futuro lançamento residencial em Jabaquara, em fase de estruturação de oportunidade, produto e viabilidade.","intro":["A oportunidade em Jabaquara foi originada pela Open Group com base em leitura de mercado local e avaliação criteriosa do potencial de desenvolvimento da área.","A operação está em estruturação: viabilidade em análise, parceiros sendo articulados e modelagem financeira em curso para alinhar capital e execução."],"facts":["Futuro lançamento","Residencial","Jabaquara - SP","Sócia da operação"],"ficha":[{"value":"A definir","label":"Tipologias","tbd":true},{"value":"A definir","label":"Metragem","tbd":true},{"value":"A definir","label":"Pavimentos","tbd":true},{"value":"A definir","label":"Unidades","tbd":true},{"value":"A definir","label":"Vagas","tbd":true},{"value":"A definir","label":"Diferencial","tbd":true},{"value":"A definir","label":"Financiamento","tbd":true},{"value":"A definir","label":"Programa","tbd":true},{"value":"A definir","label":"Construtora","tbd":true},{"value":"A definir","label":"Entrega","tbd":true}],"lazer":{"lead":"Mais de uma dezena de itens de lazer e conveniência distribuídos do térreo à cobertura.","feat":{"kicker":"Destaque","title":"CineOpen"},"items":[{"icon":"pool","label":"Piscina"},{"icon":"gym","label":"Academia"},{"icon":"cowork","label":"Coworking"},{"icon":"gourmet","label":"Espaço gourmet"},{"icon":"bbq","label":"Churrasqueira"},{"icon":"pet","label":"Pet place"},{"icon":"play","label":"Playground"},{"icon":"laundry","label":"Lavanderia"},{"icon":"bike","label":"Bicicletário"},{"icon":"market","label":"Mini market"},{"icon":"lounge","label":"Salão de festas"},{"icon":"roof","label":"Rooftop"}]},"locationStory":{"kicker":"A tese do lugar","title":"Em Jabaquara, a leitura da oportunidade vem antes do lançamento.","body":["O projeto em Jabaquara está em fase de estruturação a partir de uma leitura de mercado local e do potencial de desenvolvimento da área.","Antes de comunicar produto ou lançamento, a Open Group organiza as variáveis que sustentam a operação: território, demanda, viabilidade e parceiros.","Essa etapa inicial é decisiva para transformar uma oportunidade imobiliária em um empreendimento com direção clara."],"highlights":[{"title":"Mercado local","text":"Leitura da praça e do potencial de absorção antes da definição final do produto."},{"title":"Viabilidade em curso","text":"Análise técnica, financeira e estratégica para sustentar a evolução da operação."},{"title":"Estruturação inicial","text":"Articulação de parceiros e desenho de caminho antes do compromisso de lançamento."}]},"productStory":{"kicker":"O produto como resposta","title":"Plantas inteligentes pensadas para uma vida urbana mais prática.","body":["Em Jabaquara, a Open Group conduz a etapa em que o produto ainda está sendo calibrado a partir da oportunidade.","A definição de posicionamento, mix e estratégia comercial deve nascer da consistência entre território, demanda e execução possível."],"cards":[{"label":"Status","value":"Futuro lançamento","text":"Projeto em estruturação, ainda antes da comunicação final de mercado."},{"label":"Segmento","value":"Residencial","text":"Direção de produto voltada à moradia e ao potencial local."},{"label":"Localização","value":"Jabaquara","text":"Praça em análise para definição de posicionamento e viabilidade."},{"label":"Modelo","value":"Sócia da operação","text":"Operação construída com alinhamento entre capital, parceiros e execução."}]},"galleryIntro":{"kicker":"Do estudo à materialização","title":"A narrativa também aparece nos espaços.","body":["Enquanto o produto avança, a galeria mantém a estrutura visual da página e será atualizada com imagens, renders ou materiais oficiais do empreendimento."]},"strategyStory":{"kicker":"Estruturação Open Group","title":"A operação está sendo desenhada antes de chegar ao mercado.","body":["No projeto Jabaquara, a Open Group atua na origem: leitura da oportunidade, análise de viabilidade, modelagem financeira e articulação dos parceiros necessários.","O objetivo é preparar a operação com clareza antes do lançamento, evitando decisões desconectadas entre produto, mercado e execução."]},"closingStatement":{"title":"Jabaquara ainda está em estruturação.","text":"Um projeto em desenvolvimento, conduzido com método para transformar potencial em operação viável.","ctaLabel":"Tenho interesse no empreendimento"}},"hits-santa-catarina":{"card":{"status":"Entregue","segmento":"Residencial","local":"São Paulo · SP"},"heroSummary":"Um empreendimento residencial entregue na Vila Santa Catarina, na zona sul de São Paulo, com fácil acesso à Berrini e ao Morumbi.","intro":["O Hits Santa Catarina nasceu na Vila Santa Catarina, na zona sul de São Paulo, uma região em valorização contínua, com fácil acesso à Berrini e a cerca de 20 minutos do Morumbi Shopping. O empreendimento ocupa um terreno de 933,60 m² na esquina da Rua Oito de Março com a Emílio de Sousa Docca.","Em uma única torre de térreo + 8 pavimentos, são 84 apartamentos de 1 e 2 dormitórios de 29 a 87 m², todos com terraço com churrasqueira, e gardens com quintal no térreo. O empreendimento tem dois elevadores e lazer completo (piscina, prainha, beach sports, crossfit, espaço gourmet), já entregue."],"facts":["Entregue","1 e 2 dormitórios","Terraço com churrasqueira","Vila Santa Catarina - SP"],"ficha":[{"value":"1 e 2 dormitórios","label":"Tipologias"},{"value":"29 a 87 m²","label":"Metragem"},{"value":"Térreo + 8","label":"Pavimentos"},{"value":"84 unidades","label":"Unidades"},{"value":"1 vaga PNE","label":"Vagas"},{"value":"Terraço com churrasqueira","label":"Diferencial"},{"value":"Caixa Econômica","label":"Financiamento"},{"value":"MCMV","label":"Programa"},{"value":"TS Engenharia","label":"Construtora"},{"value":"Entregue","label":"Entrega"}],"lazer":{"lead":"Mais de uma dezena de itens de lazer e conveniência, entregues equipados e decorados.","feat":{"kicker":"Destaque","title":"Beach Sports"},"items":[{"icon":"pool","label":"Piscina"},{"icon":"beach","label":"Prainha"},{"icon":"sport","label":"Crossfit"},{"icon":"gym","label":"Fitness"},{"icon":"play","label":"Playground"},{"icon":"bbq","label":"Churrasqueira"},{"icon":"lounge","label":"Salão de festas"},{"icon":"gourmet","label":"Espaço gourmet"},{"icon":"pet","label":"Pet place"},{"icon":"laundry","label":"Lavanderia"},{"icon":"game","label":"Espaço teen"},{"icon":"toys","label":"Brinquedoteca"},{"icon":"cowork","label":"Coworking"},{"icon":"sport","label":"Ladder sport"},{"icon":"market","label":"Grab & Go"},{"icon":"bike","label":"Bike Station"}]},"locationStory":{"kicker":"A tese do lugar","title":"Na Vila Santa Catarina, a leitura do lugar precedeu a obra.","body":["Na Rua Oito de Março, o Hits Santa Catarina está inserido em uma região em valorização contínua na zona sul de São Paulo, com fácil acesso à Berrini.","O endereço fica a cerca de 20 minutos do Morumbi Shopping, com diversas linhas de ônibus nas avenidas Santa Catarina, Cupecê e Washington Luís.","Essa combinação de localização e mobilidade orientou a tese do produto e sustentou a operação até a entrega."],"highlights":[{"title":"Acesso à Berrini","text":"Conexão com um dos principais polos corporativos da cidade."},{"title":"Mobilidade consolidada","text":"Linhas de ônibus nas avenidas Santa Catarina, Cupecê e Washington Luís."},{"title":"Região em valorização","text":"Entorno com infraestrutura completa e valorização contínua."}]},"productStory":{"kicker":"O produto como resposta","title":"Plantas inteligentes pensadas para uma vida urbana mais prática.","body":["As unidades de 1 e 2 dormitórios, com terraço com churrasqueira, responderam à demanda da zona sul com eficiência e localização conectada.","A entrega evidencia o papel da OGDI em transformar oportunidade em empreendimento lançado e concluído."],"cards":[{"label":"Tipologia","value":"1 e 2 dormitórios","text":"Plantas eficientes com terraço com churrasqueira."},{"label":"Endereço","value":"Rua Oito de Março, 65","text":"Vila Santa Catarina, zona sul de São Paulo."},{"label":"Mobilidade","value":"Eixo Santa Catarina","text":"Fácil acesso à Berrini e a cerca de 20 min do Morumbi Shopping."},{"label":"Entrega","value":"Obra concluída","text":"Operação 100% entregue, do conceito ao lançamento."}]},"galleryIntro":{"kicker":"Da concepção à entrega","title":"A narrativa também aparece nos espaços.","body":["As imagens apresentam o empreendimento entregue — fachada, áreas comuns e ambientes que materializam o produto conduzido pela OGDI da concepção ao lançamento."]},"strategyStory":{"kicker":"Estruturação OGDI","title":"A entrega é consequência de decisões tomadas antes.","body":["No Hits Santa Catarina, a OGDI conduziu uma operação que reuniu leitura de oportunidade, conceituação de produto, viabilidade e articulação de parceiros.","O resultado é uma entrega que demonstra a importância da estruturação anterior ao lançamento e à execução."]},"closingStatement":{"title":"Hits Santa Catarina é uma operação entregue.","text":"Um empreendimento que reflete o valor construído antes da obra: produto posicionado, operação estruturada e lançamento conduzido.","ctaLabel":"Tenho interesse no empreendimento"}}}},"now":"$undefined","timeZone":"UTC","children":"$L3c"}]
